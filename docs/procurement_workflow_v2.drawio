        </mxCell>
        <mxCell id="n6" value="&lt;b&gt;6. Gửi YC báo giá&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Email + link/NCC&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
