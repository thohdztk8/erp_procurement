        </mxCell>
        <mxCell id="n8" value="&lt;b&gt;8. So sánh &amp; chốt giá&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Xuất IPO PDF&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="1130" y="70" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n8b" value="&lt;b&gt;8B. Sửa IPO [NEW]&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Update, ký, upload PDF&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#C00000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
