        <mxCell id="n1" value="&lt;b&gt;1. Tạo PR&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Chọn vật tư, SL, ưu tiên&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4D8;strokeColor=#3C7A3C;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane0">
          <mxGeometry x="70" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="&lt;b&gt;2. Sửa / Hủy PR&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Lịch sử thay đổi&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4D8;strokeColor=#3C7A3C;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane0">
          <mxGeometry x="260" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n1b" value="&lt;b&gt;1B. PR Khẩn [NEW]&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Lý do + mức độ&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#C00000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane0">
          <mxGeometry x="470" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n13" value="&lt;b&gt;13. Xác nhận nhận hàng&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Đánh giá CL, đóng PR&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4D8;strokeColor=#3C7A3C;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane0">
          <mxGeometry x="1830" y="60" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="nend_cancel" value="PR Hủy" style="ellipse;whiteSpace=wrap;html=1;fillColor=#404040;strokeColor=#222222;fontColor=#FFFFFF;fontStyle=1;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane0">
          <mxGeometry x="395" y="135" width="90" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="&lt;b&gt;3. Tạo cart&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Lọc PR, gom request&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="70" y="70" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="&lt;b&gt;4. Sửa cart&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Sửa SL, ghi log&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="260" y="70" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n5" value="&lt;b&gt;5. Tạo order&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Tổng hợp SL, chọn NCC&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
          <mxGeometry x="470" y="70" width="140" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n5b" value="&lt;b&gt;5B. Sửa order [NEW]&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;Thêm/sửa NCC&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#C00000;strokeWidth=2;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
