        <mxCell id="n10" value="&lt;b&gt;10. Liên hệ NCC sau duyệt&lt;/b&gt;&lt;br&gt;&lt;span style='font-size:10'&gt;[Thủ công, KHÔNG auto-mail]&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BDD7EE;strokeColor=#2E75B6;fontSize=12;align=center;verticalAlign=middle;" vertex="1" parent="lane1">
