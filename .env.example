# ── Django ───────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=change-me-to-a-long-random-string-min-50-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── MSSQL ────────────────────────────────────────────────────
DB_NAME=ProcurementDB
DB_HOST=db
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=YourStrong@Password123

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_HOURS=8
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Email (SMTP) ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=no-reply@company.com
EMAIL_HOST_PASSWORD=your-smtp-app-password

# ── Vendor Portal ────────────────────────────────────────────
VENDOR_PORTAL_BASE_URL=https://portal.company.com/vendor
QUOTATION_TOKEN_EXPIRE_HOURS=72

# ── File upload ──────────────────────────────────────────────
MEDIA_ROOT=/app/media
MAX_UPLOAD_SIZE_MB=10
CSRF_TRUSTED_ORIGINS=http://localhost:2680,http://127.0.0.1:2680,http://localhost:2681,http://127.0.0.1:2681
CSRF_TRUSTED_ORIGINS=http://localhost:2680,http://127.0.0.1:2680,http://localhost:2681,http://127.0.0.1:2681
